{
  "permissions": {
    "allow": [
      "Read(*)",

      "Bash(git checkout:*)",
      "Bash(git worktree:*)",

      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(sed:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",

      "Bash(make setup-middle:*)",
      "Bash(make generate-middle:*)",
      "Bash(make:*)",
      "Bash(xcodebuild:*)",
      "Bash(open:*)",
      "Bash(true)",

      "Bash(gh pr view:*)",
      "Bash(gh issue view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",

      "Bash(linctl:*)",

      "SlashCommand(/codeReview)",

      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git rev-parse:*)",
      "Bash(while read commit)",
      "Bash(do git show --name-only --format=\"\" $commit)",
      "Bash(echo \"Commit: $commit\")",
      "Bash(done)",
      "Bash(od:*)",
      "Bash(awk:*)",
      "Bash(git stash show:*)",
      "mcp__figma-remote-mcp__get_screenshot",
      "mcp__figma-remote-mcp__get_design_context",
      "mcp__figma-remote-mcp__get_metadata",
      "mcp__figma-remote-mcp__get_variable_defs",
      "mcp__figma-remote-mcp__get_code_connect_map",
      "mcp__figma-remote-mcp__create_design_system_rules",
      "mcp__figma-remote-mcp__whoami"
    ],
    "deny": []
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/branch-protection-pre-edit.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/skill-activation-prompt.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-tool-use-tracker.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/swiftformat-post-edit.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/notification-alert.sh"
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/notification-alert.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Evaluate if Claude should stop. Context: $ARGUMENTS\n\nCheck if:\n1. All requested tasks are complete\n2. No test failures mentioned\n3. No TODO items left\n4. User wasn't asking for more\n\nRespond with {\"ok\": true} or {\"ok\": false, \"reason\": \"...\"}",
            "timeout": 30
          }
        ]
      }
    ]
  }
}